[Unit]
Description=Primaclaw Coordinator (AI Swarm Brain)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=primaclaw
Group=primaclaw
WorkingDirectory=/opt/primaclaw
ExecStart=/opt/primaclaw/venv/bin/python -m src.coordinator
Restart=always
RestartSec=5
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
